{
  "name": "autocare",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "main": "index.js",
  "scripts": {
    "build": "pnpm --dir shared build && pnpm --dir client build && pnpm --dir server build",
    "dev": "pnpm --parallel --stream --filter ./server --filter ./client run dev",
    "dev:client": "pnpm --filter ./client run dev",
    "dev:server": "pnpm --filter ./server run dev",
    "preview": "pnpm build && pnpm run preview:start",
    "preview:start": "pnpm --parallel --stream --filter ./server --filter ./client run preview",
    "deploy": "node scripts/deploy.mjs",
    "deploy:check": "node scripts/deploy.mjs --skip-install",
    "deploy:prod": "node scripts/deploy.mjs --migrate",
    "deploy:prod:seed": "node scripts/deploy.mjs --migrate --seed",
    "lint": "pnpm --dir client lint && pnpm --dir client lint:styles && pnpm --dir server lint",
    "lint:fix": "pnpm --dir client lint:fix && pnpm --dir client lint:styles:fix && pnpm --dir server lint:fix",
    "test": "pnpm --dir server test",
    "prepare": "husky",
    "lint-staged": "pnpm --dir client lint-staged"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "husky": "9.1.7"
  }
}
